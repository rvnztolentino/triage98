{
  "info": {
    "name": "Triage98 API",
    "description": "Complete API collection for Triage98 (local-first operations triage).\n\nCovers the currently implemented surface: meta/health and auth (register, login, me), plus negative tests.\n\nUsage:\n1. Import this collection AND `triage98.postman_environment.json`, then select the \"Triage98 (local)\" environment (top-right).\n2. Start the API: `npm run dev:server` (defaults to http://localhost:4000).\n3. Run \"Auth / Register\" — it generates a unique email, creates the account, and saves the JWT into the `token` variable.\n4. Everything else (Login, Me) reuses that token automatically. Or use the Collection Runner to run the whole thing top to bottom.\n\nAuth: the collection sends `Authorization: Bearer {{token}}` by default; requests that must be anonymous override this to \"No Auth\".",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "email", "value": "", "type": "string" },
    { "key": "password", "value": "correcthorse", "type": "string" },
    { "key": "displayName", "value": "Demo User", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Meta",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "Service banner. Returns { name, status }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('reports the service name', () => pm.expect(body.name).to.eql('triage98'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Liveness + dependency probe. 200 with status 'ok' when Postgres and Redis are up; 503 'degraded' when a dependency is down (never hangs)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 503', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));",
                  "const body = pm.response.json();",
                  "pm.test('has database + redis checks', () => {",
                  "  pm.expect(body.checks).to.have.property('database');",
                  "  pm.expect(body.checks).to.have.property('redis');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique email each run so re-running never 409s.",
                  "const email = `demo+${Date.now()}@triage98.local`;",
                  "pm.collectionVariables.set('email', email);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('returns a token and user', () => {",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user.role).to.eql('requester');",
                  "});",
                  "pm.collectionVariables.set('token', body.token);",
                  "pm.collectionVariables.set('userId', body.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{displayName}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Create an account. Returns { token, user }. Rate-limited to 5/hour/IP."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns a fresh token', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('token', body.token);",
                  "pm.collectionVariables.set('userId', body.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Verify credentials, return a new session token. Uses the email captured by Register. Rate-limited to 10/min/IP."
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns the current user', () => pm.expect(body.user.id).to.eql(pm.collectionVariables.get('userId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "description": "Current user from the Bearer token (inherited from the collection)."
          }
        },
        {
          "name": "Login (wrong password) → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('generic error message', () => pm.expect(body.error.message).to.eql('Invalid email or password.'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"definitely-wrong\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Wrong password returns the same generic 401 as an unknown email (no user enumeration)."
          }
        },
        {
          "name": "Me (no token) → 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "description": "Without a Bearer token the endpoint returns 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('code is unauthorized', () => pm.expect(body.error.code).to.eql('unauthorized'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (validation) → 400",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"123\",\n  \"displayName\": \"x\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Invalid body returns 400 with per-field messages under error.details."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",
                  "pm.test('has field errors', () => {",
                  "  pm.expect(body.error.code).to.eql('bad_request');",
                  "  pm.expect(body.error.details).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
