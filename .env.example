# Triage98 environment. Copy to `.env` and adjust as needed.
# Every value below has a working local default — the defaults are what
# `docker compose up` (Postgres + Redis) exposes on localhost.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Server ---
# Port the Express API listens on.
PORT=4000
# Comma-separated origins allowed to call the API (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
# Matches the credentials in docker-compose.yml.
POSTGRES_USER=triage98
POSTGRES_PASSWORD=triage98
POSTGRES_DB=triage98
POSTGRES_PORT=5432
# Full connection string the server uses. Keep in sync with the values above.
DATABASE_URL=postgres://triage98:triage98@localhost:5432/triage98

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Change this to a long random string before any real deployment (e.g. the output
# of `openssl rand -base64 48`). Signs JWT session tokens.
JWT_SECRET=dev-insecure-change-me
# Session token lifetime (any value the `jose` library accepts, e.g. 12h, 7d).
JWT_EXPIRES_IN=7d
# bcrypt cost factor (4–15). 10 is a good default; raise for more hashing work.
BCRYPT_ROUNDS=10
# Optional: the email that becomes the seed owner on registration. Blank disables it.
SEED_ADMIN_EMAIL=

# --- File uploads (used from the requests branch onward) ---
# Directory (relative to the server package) where attachments are stored.
UPLOAD_DIR=uploads
# Per-file size cap in bytes (10 MB) and max files per request.
MAX_UPLOAD_BYTES=10485760
MAX_UPLOAD_FILES=5

# --- Local AI runtime (used from the triage-worker branch onward) ---
# Point this at your local model runtime (Ollama or compatible).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Client (Vite) ---
# Base URL the SPA uses to reach the API.
VITE_API_URL=http://localhost:4000
